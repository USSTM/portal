{
  "name": "@usstm/auth",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "generate:session-key": "node scripts/generate-session-key.mjs",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:integration": "vitest run --passWithNoTests --config vitest.integration.config.ts",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "1.19.14",
    "@usstm/auth-session": "workspace:*",
    "arctic": "^3.7.0",
    "dotenv": "17.4.2",
    "hono": "4.12.30",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
