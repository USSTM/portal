{
  "name": "usstm-portal",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @usstm/auth --filter @usstm/portal dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:integration": "pnpm -r --if-present test:integration",
    "db:migrate": "pnpm --filter @usstm/portal db:migrate",
    "build": "pnpm -r --if-present build",
    "ci": "pnpm format && pnpm lint && pnpm typecheck && pnpm test && pnpm test:integration && pnpm db:migrate && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "typescript-eslint": "8.64.0"
  }
}
